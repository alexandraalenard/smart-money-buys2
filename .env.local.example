# ============================================
# THE HIDDEN LEDGER - Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY_ID=price_...
STRIPE_PRICE_ANNUAL_ID=price_...

# --- EMAIL (Resend.com) ---
RESEND_API_KEY=re_...

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://thehiddenledger.com

# --- CRON SECRET (for alert triggers) ---
ALERT_CRON_SECRET=your-random-secret-string

# --- ADMIN DASHBOARD ---
# Server-side password for the /admin login (verified in app/api/admin/login).
# Must NOT be prefixed NEXT_PUBLIC_ — keep it server-only so it never ships to
# the browser bundle.
# ADMIN_PW=choose-a-strong-password

# ============================================
# Supabase table needed: subscribers
# Columns: id, email, plan, status,
#   stripe_customer_id, stripe_subscription_id,
#   alert_massive_trades (bool),
#   alert_billionaire_trades (bool),
#   alert_high_confidence (bool),
#   created_at
# ============================================
